<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/result_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_float_result"
    android:padding="10dp"
    android:elevation="12dp">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Skald"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface" />

        <Button
            android:id="@+id/btn_close_result"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:text="✕"
            android:textSize="12sp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            style="@style/Widget.MaterialComponents.Button.TextButton" />
    </LinearLayout>

    <!-- 加载中提示 -->
    <LinearLayout
        android:id="@+id/layout_loading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="12dp">

        <ProgressBar
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="6dp"
            style="?android:attr/progressBarStyle" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="正在分析对话..."
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- 错误提示 -->
    <TextView
        android:id="@+id/tv_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="@color/style_aggressive"
        android:gravity="center"
        android:paddingVertical="10dp"
        android:visibility="gone" />

    <!-- 可滚动内容区域 (对话 + 建议) -->
    <ScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="400dp"
        android:fillViewport="false"
        android:scrollbars="vertical"
        android:fadeScrollbars="false"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 对话预览 -->
            <LinearLayout
                android:id="@+id/layout_conversation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="2dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋 识别到的对话"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:paddingBottom="3dp" />

                <TextView
                    android:id="@+id/tv_conversation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/on_surface"
                    android:lineSpacingExtra="2dp"
                    android:padding="6dp"
                    android:scrollbars="vertical"
                    android:background="#F8F9FA" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="2dp" />
            </LinearLayout>

            <!-- 建议标题 -->
            <TextView
                android:id="@+id/tv_suggestions_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡 回复建议"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:paddingBottom="4dp"
                android:visibility="gone" />

            <!-- 话术列表 -->
            <LinearLayout
                android:id="@+id/layout_suggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
